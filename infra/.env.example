# ── Loko ERP — Docker/compose environment ─────────────────────────────────
# Copy to infra/.env (NEVER commit infra/.env) and fill in real values:
#   cp .env.example .env && nano .env

# Django core
SECRET_KEY=change-me-to-a-long-random-50-plus-char-string
DEBUG=False
# "Behind a TLS-terminating reverse proxy" (host nginx + certbot):
# enables SECURE_PROXY_SSL_HEADER + secure cookies. Keep True in production.
USE_CLOUDFLARE=True
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=31536000

# Hosts / origins (your domains)
ALLOWED_HOSTS=api.lokobooking.com,127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=https://lokobooking.com,https://www.lokobooking.com
CSRF_TRUSTED_ORIGINS=https://lokobooking.com,https://www.lokobooking.com,https://api.lokobooking.com

# PostgreSQL (runs in the `db` container; host=db, port=5434 inside the compose network)
POSTGRES_DB=loko
POSTGRES_USER=lokobooking
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5434

# Initial data is seeded MANUALLY (see infra/README.md) — keep 0 in production
# so a public API is never auto-provisioned with default credentials.
SEED_ON_START=0
# Passwords for the seeded admin/kassir users (read by `manage.py seed`).
# Without these in production the users are created WITHOUT a usable password
# (set one later via `manage.py changepassword`). Real secrets — never commit.
SEED_ADMIN_PASSWORD=change-me-admin-password
SEED_KASSIR_PASSWORD=change-me-kassir-password

# Frontend build-time API base (baked into the SPA bundle)
VITE_API_BASE_URL=https://api.lokobooking.com/api

# Host paths bind-mounted into containers (served by host nginx)
WEB_DIR=/srv/www/lokobooking
MEDIA_DIR=/srv/loko/media

# ── Optional: media → Cloudflare R2 (else local $MEDIA_DIR volume) ─────────
# R2_BUCKET=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_PUBLIC_DOMAIN=media.lokobooking.com
