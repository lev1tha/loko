# Backend base URL used by the axios client.
# In dev the Vite proxy forwards /api to the Django server (see vite.config.js),
# so the default relative "/api" works out of the box.
VITE_API_BASE_URL=/api

# Proxy target for the Django backend. Default Django runserver port is 8000.
# Override here if you run the backend on a different port.
VITE_BACKEND_URL=http://127.0.0.1:8009
