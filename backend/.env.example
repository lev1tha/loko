# ── Loko ERP backend — production environment (.env) ───────────────────────
# Copy to .env on the server and fill in real values. NEVER commit the real .env.

# Core
SECRET_KEY=change-me-to-a-long-random-50-char-string
DEBUG=False
USE_CLOUDFLARE=True

# Hosts/origins (your domains)
ALLOWED_HOSTS=api.loko.kg,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://app.loko.kg
CSRF_TRUSTED_ORIGINS=https://app.loko.kg,https://api.loko.kg

# HTTPS hardening (Cloudflare terminates TLS; keep redirect off behind the tunnel)
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=31536000

# ── PostgreSQL (leave POSTGRES_DB empty to keep SQLite) ─────────────────────
POSTGRES_DB=loko
POSTGRES_USER=loko
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# ── Cloudflare R2 (media files via django-storages) ────────────────────────
# Create an R2 bucket + API token in the Cloudflare dashboard.
R2_BUCKET=loko-media
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_PUBLIC_DOMAIN=media.loko.kg
